float4 out gl_Position : POSITION;
float4 out oColor : COLOR0;
float2 out oTexCoords : TEXCOORD0;
float4 out oTexModeWeights : TEXCOORD1;

void main(float4 position, float2 texCoords, float4 viewport, float4 color, float2 texSize, float4 texModeWeights) {
    oColor = color / 31.0;
    oTexCoords = texCoords / (texSize * 8.0);
    oTexModeWeights = texModeWeights;
    float2 screenDims = float2(255.0, 191.0);
    gl_Position = position;
    gl_Position.xy = (gl_Position.w * (viewport.zw + viewport.xy - screenDims) + (viewport.zw - viewport.xy) * gl_Position.xy) / screenDims;
}
